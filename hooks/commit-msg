#!/bin/bash
# commit-msg hook: strip AI-attribution trailers + scan subject for OPSEC leaks.
# Belt-and-suspenders backup to the CLAUDE.md instruction + settings.json
# includeCoAuthoredBy:false. Catches what slips through other layers.
#
# Why: tools don't get co-author credit. The DeWalt rule.
#
# Also: OPSEC scan on subject line — rejects session IDs, hostnames, agent
# handles, tailnet name before the commit lands in public history. Sources
# patterns from opsec-scan.sh (machine-level + repo-local .local files).
# Opt-in: if no .local files are present, only the hardcoded baseline runs
# (session IDs + Tailscale CGNAT IPs) — safe default for OSS users.

set -euo pipefail

MSG_FILE="$1"

# OPSEC scan — subject line only (first line). Bodies get more lenient
# treatment because legitimate prose may mention collaborators by name.
# opsec-scan.sh sets $opsec_patterns; gracefully degrades if no .local files.
_HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck disable=SC1091
if [ -f "$_HOOK_DIR/opsec-scan.sh" ]; then
  source "$_HOOK_DIR/opsec-scan.sh"
else
  opsec_patterns='\bS[0-9]{3}\b|100\.[0-9]{1,3}(\.[0-9]{1,3}){2}'
fi
if head -1 "$MSG_FILE" | grep -nE "$opsec_patterns" >/dev/null; then
  echo "FAIL: commit subject contains OPSEC-sensitive token(s):" >&2
  head -1 "$MSG_FILE" | grep -nE "$opsec_patterns" >&2
  echo "" >&2
  echo "Strip session IDs (Sxxx), hostnames, agent handles, tailnet name from" >&2
  echo "the subject. Rephrase to a functional description." >&2
  echo "If you've verified this is a false positive, use --no-verify (humans only)." >&2
  exit 1
fi
unset _HOOK_DIR

TMP_FILE="$(mktemp)"

# Strip lines matching any of these patterns (case-insensitive).
# Patterns kept ASCII-only — multibyte emoji handling in grep is unreliable
# across locales, so we match the surrounding text instead.
grep -ivE \
    -e 'Co-Authored-By:.*Claude' \
    -e 'Co-Authored-By:.*Copilot' \
    -e 'Co-Authored-By:.*Cursor' \
    -e 'Co-Authored-By:.*Gemini' \
    -e 'Co-Authored-By:.*ChatGPT' \
    -e 'Co-Authored-By:.*GitHub[[:space:]]Copilot' \
    -e 'Co-Authored-By:.*anthropic' \
    -e 'Co-Authored-By:.*noreply@anthropic\.com' \
    -e 'Co-Authored-By:.*<AI' \
    -e 'Co-Authored-By:.*\bAI\b' \
    -e 'Generated[[:space:]]with[[:space:]]Claude' \
    -e 'Generated[[:space:]]with[[:space:]]Copilot' \
    -e 'Generated[[:space:]]with[[:space:]]Cursor' \
    -e 'Generated[[:space:]]with[[:space:]]Gemini' \
    -e 'Generated-with:.*Claude' \
    -e 'AI-assisted:' \
    -e 'Written[[:space:]]by[[:space:]]Claude' \
    -e 'Created[[:space:]]by[[:space:]]Claude' \
    -e 'noreply@anthropic\.com' \
    -e 'noreply@github\.com.*copilot' \
    "$MSG_FILE" 2>/dev/null > "$TMP_FILE" || cp "$MSG_FILE" "$TMP_FILE"

# Collapse runs of 2+ blank lines into 1, strip leading + trailing blanks
awk '
BEGIN { pending_blank = 0; first = 1 }
/^[[:space:]]*$/ {
    pending_blank = 1
    next
}
{
    if (pending_blank && !first) print ""
    pending_blank = 0
    first = 0
    print
}
' "$TMP_FILE" > "$MSG_FILE"
rm -f "$TMP_FILE"

exit 0
