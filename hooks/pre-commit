#!/bin/bash
# Pre-commit Secret Detection Hook
# Two layers: (1) fast regex first-pass for known secret shapes,
# (2) gitleaks scan of staged files for broad coverage (when installed).

set -u  # catch unset vars only — NOT set -e (gitleaks wrapper is unreliable with it)

if ! command -v gitleaks >/dev/null 2>&1; then
    echo "⚠  gitleaks not installed — broad secret scan skipped (regex only)."
    echo "    Install: https://github.com/gitleaks/gitleaks/releases"
    GITLEAKS_AVAILABLE=0
else
    GITLEAKS_AVAILABLE=1
fi

FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$FILES" ]; then
    exit 0
fi

FILE_COUNT=$(echo "$FILES" | wc -l)
echo "🔍 Scanning $FILE_COUNT staged files for secrets..."

# Layer 1: high-precision regex patterns for known secret shapes.
PATTERNS=(
    "AWS_ACCESS_KEY_ID.*=.*AKIA[0-9A-Z]{16}"
    "AWS_SECRET_ACCESS_KEY.*=.*[0-9a-zA-Z/+]{40}"
    "sk-or-[a-zA-Z0-9]{48}"
    "ghp_[a-zA-Z0-9]{36}"
    "gho_[a-zA-Z0-9]{36}"
    "ghu_[a-zA-Z0-9]{36}"
    "ghs_[a-zA-Z0-9]{36}"
    "ghr_[a-zA-Z0-9]{36}"
    "github_pat_[a-zA-Z0-9]{82}"
    "xoxb-[0-9]{13}-[0-9]{13}-[a-zA-Z0-9]{24}"
    "xoxp-[0-9]{13}-[0-9]{13}-[0-9]{13}-[a-zA-Z0-9]{32}"
    "AKIA[0-9A-Z]{16}"
    "Bearer [a-zA-Z0-9+/]{40,}"
    "api_key\\s*=\\s*['\"][a-zA-Z0-9]{32,}['\"]"
    "secret\\s*=\\s*['\"][a-zA-Z0-9]{32,}['\"]"
    "password\\s*=\\s*['\"][^'\"]{8,}['\"]"
    "token\\s*=\\s*['\"][a-zA-Z0-9]{32,}['\"]"
)

SECRETS_FOUND=0
FOUND_IN=""

# Skip third-party minified bundles + test/example fixtures — they have
# realistic-looking fake keys (sk_test_, AKIAFAKE..., etc.) for testing/docs.
# Real secrets live in source/config files.
skip_path() {
    case "$1" in
        # Third-party / vendored
        .obsidian/plugins/*/main.js|.obsidian/plugins/*/styles.css) return 0 ;;
        node_modules/*|*/node_modules/*) return 0 ;;
        vendor/*|*/vendor/*|third_party/*|*/third_party/*) return 0 ;;
        *.min.js|*.min.css) return 0 ;;
        # Test / spec / fixtures
        test/*|*/test/*|tests/*|*/tests/*|__tests__/*|*/__tests__/*) return 0 ;;
        spec/*|*/spec/*|fixtures/*|*/fixtures/*) return 0 ;;
        *_test.*|*.test.*|*.spec.*|*_spec.*) return 0 ;;
        # Examples / samples / docs
        example/*|*/example/*|examples/*|*/examples/*) return 0 ;;
        sample/*|*/sample/*|samples/*|*/samples/*) return 0 ;;
        demo/*|*/demo/*|docs/*|*/docs/*) return 0 ;;
        # Template / placeholder file extensions
        *.example|*.sample|*.template|*.dist|*.tpl) return 0 ;;
        *.env.example|*.env.sample) return 0 ;;
        example.env|sample.env) return 0 ;;
        *) return 1 ;;
    esac
}

while IFS= read -r file; do
    if [ ! -f "$file" ]; then
        continue
    fi

    if skip_path "$file"; then
        continue
    fi

    for pattern in "${PATTERNS[@]}"; do
        if grep -qiE "$pattern" "$file" 2>/dev/null; then
            SECRETS_FOUND=1
            FOUND_IN="$FOUND_IN  - $file (matched: $(echo "$pattern" | cut -c1-30)...)"
            break
        fi
    done
done <<< "$FILES"

if [ $SECRETS_FOUND -eq 1 ]; then
    echo ""
    echo "❌ POTENTIAL SECRET DETECTED! Commit blocked."
    echo ""
    echo "Found patterns matching secret formats in:"
    echo "$FOUND_IN"
    echo ""
    echo "Common fixes:"
    echo "  - Move to .env file (add to .gitignore)"
    echo "  - Use environment variables"
    echo "  - Store in Vault"
    echo ""
    echo "To bypass (NOT RECOMMENDED): git commit --no-verify"
    echo ""
    exit 1
fi

# Layer 2: gitleaks — broader coverage (~700+ built-in detectors).
if [ "$GITLEAKS_AVAILABLE" -eq 1 ]; then
    if ! gitleaks protect --staged --redact --verbose 2>&1; then
        echo ""
        echo "❌ gitleaks: potential secret detected. Commit blocked."
        echo ""
        echo "To bypass (NOT RECOMMENDED): git commit --no-verify"
        echo "If verified false positive: add to .gitleaksignore"
        echo ""
        exit 1
    fi
fi

# Layer 3: OPSEC content scan — infrastructure identifiers (hostnames, agent
# handles, codenames, tailnet name) in staged content + filenames. Catches
# what credential-shaped regex can't: a fleet hostname in a comment, an
# agent handle in a docstring, a tailnet suffix in a URL.
#
# Sources the same opsec-scan.sh library as commit-msg, so machine-level
# ~/.config/opsec-patterns.local and repo-level ./.opsec-patterns.local apply.
# Honors `git config opsec.scan disable` — when opt-out is set, opsec-scan.sh
# leaves $opsec_patterns empty and this layer is a no-op.
#
# Scans ADDED lines only (diff ^+), not the full file. This avoids resurfacing
# legacy mentions in unchanged prose that may be legitimate. New leaks get
# caught; historical mentions stay a separate cleanup problem.
#
# Reuses skip_path() — test fixtures, *.example templates, node_modules, etc.
# are exempt (same policy as Layers 1 + 2).
if [ -z "${opsec_patterns:-}" ] && [ "${OPSEC_SCAN_LOADED:-0}" != "1" ]; then
    _HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
    if [ -f "$_HOOK_DIR/opsec-scan.sh" ]; then
        # shellcheck disable=SC1091
        source "$_HOOK_DIR/opsec-scan.sh"
    fi
    OPSEC_SCAN_LOADED=1
    unset _HOOK_DIR
fi

OPSEC_LEAKS=0
OPSEC_FOUND=""

if [ -n "${opsec_patterns:-}" ]; then
    while IFS= read -r file; do
        [ -f "$file" ] || continue
        skip_path "$file" && continue

        # Filename scan — catches myhost-config.yaml, myhandle-deploy.sh, etc.
        if echo "$file" | grep -qE "$opsec_patterns"; then
            OPSEC_LEAKS=1
            OPSEC_FOUND="${OPSEC_FOUND}  - FILENAME ${file}\\n"
        fi

        # Content scan — added lines only (skip diff header +++ b/file).
        while IFS= read -r line; do
            [ -n "$line" ] || continue
            OPSEC_LEAKS=1
            OPSEC_FOUND="${OPSEC_FOUND}  - ${file}: ${line}\\n"
        done < <(git diff --cached -U0 -- "$file" 2>/dev/null \
                 | grep -E '^\+' \
                 | grep -vE '^\+\+\+' \
                 | grep -E "$opsec_patterns" 2>/dev/null)
    done <<< "$FILES"

    if [ $OPSEC_LEAKS -eq 1 ]; then
        echo ""
        echo "❌ OPSEC LEAK DETECTED in staged content. Commit blocked."
        echo ""
        echo "Found sensitive patterns in added lines / filenames:"
        printf "%b" "$OPSEC_FOUND"
        echo ""
        echo "These match your ~/.config/opsec-patterns.local (machine-level)"
        echo "or ./.opsec-patterns.local (repo-level). Remove the leak, or if"
        echo "verified false positive: use --no-verify (humans only)."
        echo ""
        echo "To disable OPSEC scan for this repo: git config opsec.scan disable"
        echo ""
        exit 1
    fi
fi

echo "✅ No secrets detected. Proceeding with commit..."
exit 0
